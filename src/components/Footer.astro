---
const year = new Date().getFullYear();

const links = [
  { href: '/', label: 'Home' },
  { href: '/portfolio', label: 'Work' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const social = [
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/andrewscottcampbell/',
    icon: `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
];
---

<footer class="border-t border-slate-100 bg-white">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <div>
        <a href="/" class="font-bold text-sm tracking-tight text-slate-900">
          POLYCHLORINATED
        </a>
        <p class="mt-1 text-xs text-slate-400">Growth Without Brute Force.</p>
      </div>

      <nav class="flex flex-wrap gap-6">
        {links.map(({ href, label }) => (
          <a href={href} class="text-sm text-slate-500 hover:text-slate-900 transition-colors">
            {label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        {social.map(({ href, label, icon }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={label}
            class="text-slate-400 hover:text-slate-700 transition-colors"
            set:html={icon}
          />
        ))}
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-slate-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <p class="text-xs text-slate-400">&copy; {year} Polychlorinated Ventures. All rights reserved.</p>
      <p class="text-xs text-slate-400">
        Built with <a href="https://astro.build" class="hover:text-slate-600 transition-colors">Astro</a>
        &amp; hosted on <a href="https://pages.cloudflare.com" class="hover:text-slate-600 transition-colors">Cloudflare Pages</a>.
      </p>
    </div>
  </div>
</footer>
