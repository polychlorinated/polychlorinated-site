---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/portfolio', label: 'Work' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300"
  data-scrolled="false"
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="hover:opacity-70 transition-opacity">
      <img src="/logo.svg" alt="Polychlorinated Ventures" class="h-8 w-auto" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-4 py-2 text-sm rounded-md transition-colors',
            isActive(href)
              ? 'text-slate-900 font-medium'
              : 'text-slate-500 hover:text-slate-900 hover:bg-slate-50',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="/contact"
        class="ml-3 px-4 py-2 text-sm font-medium bg-slate-900 text-white rounded-md hover:bg-slate-700 transition-colors"
      >
        Contact
      </a>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 rounded-md text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-slate-100 bg-white"
  >
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'px-3 py-2.5 text-sm rounded-md transition-colors',
            isActive(href)
              ? 'text-slate-900 font-medium bg-slate-50'
              : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50',
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="/contact"
        class="mt-2 px-3 py-2.5 text-sm font-medium text-center bg-slate-900 text-white rounded-md hover:bg-slate-700 transition-colors"
      >
        Contact
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  // Scroll shadow
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 10;
    header.dataset.scrolled = String(scrolled);
    header.classList.toggle('bg-white/90', scrolled);
    header.classList.toggle('backdrop-blur-sm', scrolled);
    header.classList.toggle('border-b', scrolled);
    header.classList.toggle('border-slate-100', scrolled);
    header.classList.toggle('shadow-sm', scrolled);
  }, { passive: true });

  // Mobile toggle
  btn.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
  });
</script>
