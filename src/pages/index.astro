---
import Layout from '@/layouts/Layout.astro';
import { services } from '@/data/services';
import { clients } from '@/data/portfolio';
import { getPosts, getExcerpt, formatDate } from '@/lib/wordpress';

const recentPosts = await getPosts({ perPage: 3 });
---

<Layout>
  <!-- Hero -->
  <section class="min-h-screen flex items-center pt-16">
    <div class="max-w-6xl mx-auto px-6 py-24 lg:py-32">
      <div class="max-w-4xl">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-blue-600 mb-8">
          Polychlorinated Ventures
        </p>
        <h1 class="text-6xl sm:text-7xl lg:text-8xl font-bold text-slate-900 leading-none mb-8">
          Growth Without<br class="hidden sm:block" /> Brute Force.
        </h1>
        <p class="text-xl text-slate-500 max-w-xl leading-relaxed mb-12">
          We build precise go-to-market systems and AI-powered marketing engines
          for companies that want to scale without the chaos.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/portfolio"
            class="inline-flex items-center gap-2 px-6 py-3.5 bg-slate-900 text-white text-sm font-medium rounded-md hover:bg-slate-700 transition-colors"
          >
            View Work
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center px-6 py-3.5 border border-slate-200 text-slate-700 text-sm font-medium rounded-md hover:border-slate-400 hover:text-slate-900 transition-colors"
          >
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-slate-50 py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-16">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-blue-600 mb-3">Services</p>
        <h2 class="text-4xl font-bold text-slate-900">What We Do</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {services.map((service) => (
          <div class="bg-white rounded-2xl p-8 border border-slate-100 hover:border-slate-200 hover:shadow-sm transition-all group">
            <p class="text-xs font-semibold tracking-widest uppercase text-slate-400 mb-4">
              {service.tagline}
            </p>
            <h3 class="text-2xl font-bold text-slate-900 mb-4 group-hover:text-blue-600 transition-colors">
              {service.name}
            </h3>
            <p class="text-slate-500 leading-relaxed text-sm">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Clients -->
  <section class="py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-16">
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-blue-600 mb-3">Portfolio</p>
        <h2 class="text-4xl font-bold text-slate-900">Selected Clients</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {clients.map((client) => (
          <div class="group relative flex flex-col justify-between p-5 rounded-xl border border-slate-100 hover:border-slate-300 hover:bg-slate-50 transition-all">
            <span class="text-[10px] font-semibold tracking-widest uppercase text-slate-300 mb-3 block">
              {client.category}
            </span>
            <span class="text-sm font-medium text-slate-800">{client.name}</span>
          </div>
        ))}
      </div>
      <div class="mt-10">
        <a
          href="/portfolio"
          class="text-sm font-medium text-blue-600 hover:text-blue-800 inline-flex items-center gap-1 transition-colors"
        >
          View full portfolio
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="bg-slate-900 py-24 lg:py-32 text-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-blue-400 mb-6">About</p>
          <h2 class="text-4xl font-bold mb-6 leading-tight">
            Scientific Precision Applied to Business Growth
          </h2>
          <p class="text-slate-400 leading-relaxed mb-4">
            Andrew Campbell holds a Ph.D. in chemistry and has spent years translating the methodical
            rigor of scientific research into practical, measurable business strategy.
          </p>
          <p class="text-slate-400 leading-relaxed mb-10">
            At Polychlorinated Ventures, that means working through the "messy" parts of marketing and
            operations to design systems that grow with precision — not brute force.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="https://www.linkedin.com/in/andrewscampbell/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-slate-900 text-sm font-medium rounded-md hover:bg-slate-100 transition-colors"
            >
              LinkedIn
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
            <a
              href="/contact"
              class="inline-flex items-center px-5 py-2.5 border border-slate-600 text-slate-300 text-sm font-medium rounded-md hover:border-slate-400 hover:text-white transition-colors"
            >
              Work Together
            </a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700">
            <p class="text-3xl font-bold text-white mb-2">Ph.D.</p>
            <p class="text-sm text-slate-400">Chemistry background informing every strategy</p>
          </div>
          <div class="bg-slate-800 rounded-2xl p-6 border border-slate-700">
            <p class="text-3xl font-bold text-white mb-2">12+</p>
            <p class="text-sm text-slate-400">Client engagements across GTM and automation</p>
          </div>
          <div class="bg-blue-600 rounded-2xl p-6 col-span-2">
            <p class="text-sm font-semibold text-blue-100 mb-2">The Principle</p>
            <p class="text-white leading-relaxed text-sm">
              "The best growth systems are built like good experiments — testable, measurable, and
              designed to isolate what actually works."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog preview -->
  {recentPosts.length > 0 && (
    <section class="py-24 lg:py-32">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-16">
          <div>
            <p class="text-xs font-semibold tracking-[0.2em] uppercase text-blue-600 mb-3">Writing</p>
            <h2 class="text-4xl font-bold text-slate-900">Latest Posts</h2>
          </div>
          <a
            href="/blog"
            class="hidden sm:inline-flex text-sm font-medium text-blue-600 hover:text-blue-800 items-center gap-1 transition-colors"
          >
            All posts →
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {recentPosts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col rounded-2xl border border-slate-100 hover:border-slate-200 hover:shadow-sm overflow-hidden transition-all"
            >
              <div class="p-7 flex flex-col flex-1">
                <time class="text-xs text-slate-400 mb-4 block">{formatDate(post.date)}</time>
                <h3
                  class="text-lg font-semibold text-slate-900 mb-3 group-hover:text-blue-600 transition-colors leading-snug"
                  set:html={post.title.rendered}
                />
                <p class="text-sm text-slate-500 leading-relaxed flex-1">
                  {getExcerpt(post, 120)}
                </p>
                <span class="mt-6 text-xs font-semibold text-blue-600 group-hover:gap-2 transition-all inline-flex items-center gap-1">
                  Read more →
                </span>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-8 sm:hidden">
          <a href="/blog" class="text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">
            All posts →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="border-t border-slate-100 py-24 lg:py-32">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-6">
        Ready to build something that scales?
      </h2>
      <p class="text-xl text-slate-500 mb-12 max-w-lg mx-auto">
        Let's talk about your growth challenges and find the right system to solve them.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-4 bg-slate-900 text-white font-medium rounded-md hover:bg-slate-700 transition-colors"
      >
        Start the conversation
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
